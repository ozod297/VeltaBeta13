# Bu faylni .env.local nomiga nusxalab, haqiqiy qiymatlarni kiriting.
# Production uchun esa shu o'zgaruvchilarni Vercel loyihasi
# Settings -> Environment Variables bo'limida sozlang.

# ── Telegram bot (api/bot.js, api/contact.js) ──
BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# ── Admin panel (api/admin-login.js) ──
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
